<% content_for :title, "Team | Loop AI" %>

<div class="container py-4">
  <div class="mb-4">
    <%= render "shared/page_header", eyebrow: "Workspace",
          title: "Team",
          subtitle: "Invite teammates and manage their access." %>
  </div>

  <% if current_user_workspace_admin? %>
    <%= form_with model: @team_member, url: team_path, class: "d-flex flex-wrap align-items-end gap-3 mb-4" do |form| %>
      <% if @team_member.errors.any? %>
        <div class="alert alert-danger w-100">
          <%= @team_member.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div>
        <%= form.label :email, class: "form-label" %>
        <%= form.email_field :email, class: "form-control", placeholder: "teammate@example.com" %>
      </div>

      <div>
        <%= form.label :role, class: "form-label" %>
        <%= form.select :role, Team.roles.keys.map { |role| [role.capitalize, role] }, {}, class: "form-select" %>
      </div>

      <div>
        <%= form.submit "Send invite", class: "btn btn-primary" %>
      </div>
    <% end %>
  <% end %>

  <% if @team_members.any? %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <% if current_user_workspace_admin? %>
              <th></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @team_members.each do |team_member| %>
            <tr>
              <td><%= team_member.email %></td>
              <td>
                <%= form_with model: team_member, url: team_member_path(team_member), method: :patch,
                      data: { controller: "range-filter" } do |form| %>
                  <%= form.select :role, Team.roles.keys.map { |role| [role.capitalize, role] }, {},
                        id: "team_role_#{team_member.id}",
                        class: "form-select form-select-sm", style: "width: auto;",
                        disabled: !current_user_workspace_admin?,
                        data: { action: "change->range-filter#submit" } %>
                <% end %>
              </td>
              <td>
                <% if team_member.accepted? %>
                  <span class="badge text-bg-success">Joined</span>
                <% else %>
                  <span class="badge text-bg-warning">Invited</span>
                <% end %>
              </td>
              <% if current_user_workspace_admin? %>
                <td>
                  <%= button_to team_member_path(team_member), method: :delete, class: "btn btn-sm btn-outline-danger",
                        "aria-label": "Revoke access for #{team_member.email}", title: "Revoke access",
                        data: { controller: "tooltip", bs_placement: "top" },
                        form: { data: { turbo_confirm: "Revoke access for #{team_member.email}?" } } do %>
                    <i class="fa-solid fa-user-slash" aria-hidden="true"></i>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-light border text-center py-5">
      No teammates yet. Invite someone above.
    </div>
  <% end %>
</div>
