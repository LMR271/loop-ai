<details class="deploy-loop border rounded">
  <summary class="deploy-loop__summary">
    <span class="deploy-loop__summary-content">
      <span class="deploy-loop__name">#<%= loop.name.presence || "Untitled loop" %></span>
      <% if loop.description.present? %>
        <span class="deploy-loop__description"><%= loop.description %></span>
      <% end %>
    </span>
    <span class="deploy-loop__summary-meta">
      <span class="badge text-bg-light"><%= loop.status %></span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </span>
  </summary>

  <div class="deploy-loop__details">
    <article class="deploy-detail-card deploy-status-card card">
      <div class="deploy-status-card__content">
        <p class="deploy-detail-card__eyebrow">Loop status</p>

        <% if loop.locked? %>
          <h3 class="h5 mb-1">This loop is currently paused</h3>
          <p class="text-muted mb-0">
            This loop has been launched before and is currently paused. It can be relaunched, but it can no longer be edited.
          </p>
        <% else %>
          <h3 class="h5 mb-1">This loop is not live</h3>
          <p class="text-muted mb-0">
            Launch it to make it available to respondents.
          </p>
        <% end %>
      </div>
      <div class="deploy-status-card__actions">
        <% if current_user_workspace_admin? %>
          <%= button_to activate_loop_path(loop), params: { return_to: "deploy" }, class: "btn btn-primary",
                "aria-label": "Launch #{loop.name.presence || "this loop"}", title: "Launch",
                data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-play" aria-hidden="true"></i>
          <% end %>
        <% end %>

        <% unless loop.locked? %>
          <%= link_to edit_loop_path(loop), class: "btn btn-outline-secondary",
                "aria-label": "Edit #{loop.name.presence || "this loop"}", title: "Edit",
                data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <% end %>
        <% end %>
      </div>
    </article>

    <article class="deploy-detail-card deploy-share-card card" data-controller="clipboard">
      <div>
        <p class="deploy-detail-card__eyebrow">Public link</p>
        <h3 class="h5 mb-1">Share this loop</h3>
        <p class="text-muted mb-0">Copy the link to send respondents to this interview.</p>
      </div>
      <div class="respondent-link-controls deploy-share-card__controls">
        <input id="respondent-link-<%= loop.id %>" type="text" class="form-control bg-white respondent-link-controls__url" readonly
               value="<%= respondent_url(loop.slug) %>" aria-label="Public link for <%= loop.name %>"
               data-clipboard-target="source">
        <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                data-clipboard-target="button" aria-label="Copy link" title="Copy"
                data-controller="tooltip" data-bs-placement="top">
          <i class="fa-solid fa-copy" aria-hidden="true"></i>
        </button>
        <%= link_to respondent_url(loop.slug), class: "btn btn-outline-secondary respondent-link-controls__button",
              target: "_blank", rel: "noopener",
              "aria-label": "Open link", title: "Open", data: { controller: "tooltip", bs_placement: "top" } do %>
          <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
        <% end %>
      </div>
    </article>
  </div>
</details>
