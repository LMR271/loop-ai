<% content_for :title, "Edit #{@loop.name} · Loop AI" %>

<main class="container py-5" style="max-width: 760px;">
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h1 class="mb-1">Edit <%= @loop.name %></h1>
      <p class="text-muted mb-0">Keep the conversation focused and in the order that makes sense.</p>
    </div>
    <div class="ms-3 text-end text-nowrap">
      <% if @loop.pending_approval? %>
        <span class="badge bg-warning fs-6 d-block mb-2">Pending approval</span>
        <% if current_user_workspace_admin? %>
          <%= button_to "Approve", approve_loop_path(@loop), class: "btn btn-outline-success btn-sm" %>
        <% end %>
      <% elsif @loop.active? %>
        <span class="badge bg-success fs-6 d-block mb-2">Active</span>
        <% if current_user_workspace_admin? %>
          <%= button_to "Deactivate", deactivate_loop_path(@loop), class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
      <% elsif current_user_workspace_admin? %>
        <%= button_to "Activate", activate_loop_path(@loop), class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <% if @loop.active? %>
    <div class="card border-0 bg-light mb-4" data-controller="clipboard">
      <div class="card-body">
        <label for="respondent-link" class="form-label fw-semibold mb-1">Respondent link</label>
        <p class="text-muted small mb-2">Share this link so people can talk to your agent.</p>
        <div class="input-group">
          <input id="respondent-link" type="text" class="form-control bg-white" readonly
                 value="<%= respondent_url(@loop.slug) %>"
                 data-clipboard-target="source">
          <button class="btn btn-outline-secondary" type="button" data-action="clipboard#copy"
                  data-clipboard-target="button">Copy</button>
          <%= link_to "Open", respondent_url(@loop.slug),
                class: "btn btn-outline-secondary", target: "_blank", rel: "noopener" %>
        </div>
      </div>
    </div>
  <% end %>

  <%= render "form", loop: @loop %>
</main>
