<% content_for :title, "Deploy loops · Loop AI" %>

<section class="deploy-dashboard mx-auto">
  <div class="mb-5">
    <p class="text-uppercase text-muted fw-semibold small mb-1">Deployment</p>
    <h1 class="mb-1">Deploy your loops</h1>
    <p class="text-muted mb-0">Select a loop to launch it and share its public interview link.</p>
  </div>

  <% if @loops.any? %>
    <section class="deploy-list d-grid gap-3" aria-label="Loops ready to deploy">
      <% @loops.each do |loop| %>
        <details class="deploy-loop border rounded">
          <summary class="deploy-loop__summary">
            <span class="deploy-loop__summary-content">
              <span class="deploy-loop__name">#<%= loop.name.presence || "Untitled loop" %></span>
              <% if loop.description.present? %>
                <span class="deploy-loop__description"><%= loop.description %></span>
              <% end %>
            </span>
            <span class="deploy-loop__summary-meta">
              <span class="badge text-bg-light"><%= loop.status %></span>
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </span>
          </summary>

          <div class="deploy-loop__details">
            <article class="deploy-detail-card card">
              <div>
                <p class="deploy-detail-card__eyebrow">Loop status</p>
                <h2 class="h5 mb-1">This loop is not live</h2>
                <p class="text-muted mb-0">Launch it to make it available to respondents.</p>
              </div>
              <%= button_to "Launch loop", activate_loop_path(loop),
                    params: { return_to: "deploy" }, class: "btn btn-primary" %>
            </article>

            <article class="deploy-detail-card deploy-share-card card" data-controller="clipboard">
              <div>
                <p class="deploy-detail-card__eyebrow">Public link</p>
                <h2 class="h5 mb-1">Share this loop</h2>
                <p class="text-muted mb-0">Copy the link to send respondents to this interview.</p>
              </div>
              <div class="input-group deploy-share-card__controls">
                <input id="respondent-link-<%= loop.id %>" type="text" class="form-control bg-white" readonly
                       value="<%= respondent_url(loop.slug) %>" aria-label="Public link for <%= loop.name %>"
                       data-clipboard-target="source">
                <button class="btn btn-outline-secondary" type="button" data-action="clipboard#copy"
                        data-clipboard-target="button">Copy</button>
                <%= link_to "Open", respondent_url(loop.slug), class: "btn btn-outline-secondary",
                      target: "_blank", rel: "noopener" %>
              </div>
            </article>
          </div>
        </details>
      <% end %>
    </section>
  <% else %>
    <section class="deploy-empty-state text-center" aria-labelledby="deploy-empty-heading">
      <div class="deploy-empty-state__icon" aria-hidden="true"><i class="fa-solid fa-rocket"></i></div>
      <h2 id="deploy-empty-heading">Everything is live</h2>
      <p class="text-muted mb-0">All of your loops are currently deployed.</p>
    </section>
  <% end %>
</section>
