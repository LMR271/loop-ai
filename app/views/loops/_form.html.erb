<div data-controller="questions-form">
<%= form_with model: loop do |form| %>
  <% if loop.errors.any? %>
    <div class="alert alert-danger">
      <%= loop.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", autofocus: true, required: true %>
  </div>

  <div class="mb-5">
    <%= form.label :description, "What do you want feedback on?", class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 4,
          placeholder: "Describe the product, decision, or experience you want to understand." %>
  </div>

  <section aria-labelledby="questions-heading">
    <div class="mb-3 d-flex justify-content-between align-items-end gap-3">
      <div>
        <h2 id="questions-heading" class="h4 mb-1">Conversation questions</h2>
        <p class="text-muted mb-0">These guide the feedback conversation. Use the arrows to set their order.</p>
      </div>
      <button type="button" class="btn btn-outline-secondary flex-shrink-0" data-bs-toggle="modal" data-bs-target="#insertQuestionFromLibraryModal">
        <i class="fa-solid fa-book-open" aria-hidden="true"></i>
        Insert from Library
      </button>
    </div>

    <div data-questions-form-target="list">
      <%= form.fields_for :questions do |question_fields| %>
        <%= render "question_fields", question_fields: question_fields %>
      <% end %>
    </div>

    <button type="button" class="btn app-login-button question-add-control w-100" data-action="questions-form#add">
      <i class="fa-solid fa-plus" aria-hidden="true"></i>
      Add another question
    </button>

    <template data-questions-form-target="template">
      <%= form.fields_for :questions, Question.new, child_index: "NEW_RECORD" do |question_fields| %>
        <%= render "question_fields", question_fields: question_fields %>
      <% end %>
    </template>
  </section>

  <div class="mt-4 d-flex gap-2">
    <%= button_tag type: "submit", class: "app-new-loop-button loop-form__submit" do %>
      <span><%= loop.persisted? ? "Save changes" : "Create loop" %></span>
      <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
    <% end %>
    <% if loop.persisted? %>
      <%= link_to "Cancel", edit_loop_path(loop), class: "btn app-login-button" %>
    <% end %>
  </div>
<% end %>

<%= render "question_library_modal", library_entries: @question_library_entries, library_categories: @question_library_categories %>
</div>
