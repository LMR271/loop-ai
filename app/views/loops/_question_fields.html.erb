<div class="question-editor card mb-3" data-questions-form-target="question">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
      <span class="question-editor__number" data-questions-form-target="number">Question</span>
      <div class="btn-group" aria-label="Reorder question">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="questions-form#moveUp" aria-label="Move question up">↑</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="questions-form#moveDown" aria-label="Move question down">↓</button>
      </div>
    </div>
    <%= question_fields.hidden_field :position, data: { questions_form_target: "position" } %>
    <%= question_fields.hidden_field :_destroy %>
    <%= question_fields.text_area :body, class: "form-control", rows: 2,
          placeholder: "For example: What is the most frustrating part of your current workflow?" %>
    <div class="mt-3 d-flex gap-2">
      <button type="button" class="btn btn-sm btn-outline-secondary" data-action="questions-form#openSaveModal">
        <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
        Save to Library
      </button>
      <button type="button" class="btn btn-sm btn-outline-danger" data-action="questions-form#remove">Remove question</button>
    </div>
  </div>
</div>
