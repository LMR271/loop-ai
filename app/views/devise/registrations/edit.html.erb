<% content_for :title, "Settings" %>

<div class="page-content--wide container py-4">
  <h1 class="mb-4">Settings</h1>

  <div class="row g-4">
    <div class="col-lg-6">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name),
                          html: { method: :put, class: "h-100" }) do |f| %>
        <%= f.error_notification %>

        <section class="settings-card h-100">
          <h2 class="h5 mb-1">Profile</h2>
          <p class="text-muted small mb-4">Your name and login details.</p>

          <%= f.input :name, required: false, autofocus: true %>
          <%= f.input :email, required: true %>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
          <% end %>

          <%= f.input :password,
                      hint: "leave it blank if you don't want to change it",
                      required: false,
                      input_html: { autocomplete: "new-password" } %>
          <%= f.input :password_confirmation,
                      required: false,
                      input_html: { autocomplete: "new-password" } %>
          <%= f.input :current_password,
                      hint: "Enter your current password to save any of the changes above.",
                      required: true,
                      input_html: { autocomplete: "current-password" } %>

          <%= f.button :submit, "Save changes", class: "btn btn-primary" %>
        </section>
      <% end %>
    </div>

    <div class="col-lg-6">
      <%= simple_form_for(current_organization, url: workspace_path, method: :patch, html: { class: "h-100" }) do |f| %>
        <section class="settings-card h-100">
          <h2 class="h5 mb-1">Organization</h2>
          <p class="text-muted small mb-4">Shown to your team, and applied to the interview page your respondents see.</p>

          <% unless current_user_workspace_admin? %>
            <p class="text-muted small mb-3"><i class="fa-solid fa-lock" aria-hidden="true"></i> Only admins can edit organization settings.</p>
          <% end %>

          <fieldset <%= "disabled" unless current_user_workspace_admin? %>>
            <%= f.input :name, label: "Organization name", required: false %>

            <div class="mb-4">
              <label class="form-label d-block">Logo</label>

              <% if current_organization.logo.attached? %>
                <div class="mb-2">
                  <%= image_tag current_organization.logo.variant(resize_to_limit: [120, 120]), class: "img-fluid rounded border" %>
                </div>
                <%= f.input :remove_logo, as: :boolean, label: "Remove current logo" %>
              <% end %>

              <%= f.input :logo, as: :file, label: false,
                          hint: "PNG, JPEG, WEBP, or SVG.",
                          input_html: { accept: "image/png,image/jpeg,image/webp,image/svg+xml" } %>
            </div>

            <fieldset class="mb-4">
              <legend class="h6">Theme</legend>

              <div class="row row-cols-4 g-3">
                <div class="col">
                  <%= f.input :theme_background_color, label: "Background",
                              input_html: { type: "color", class: "form-control-color" } %>
                </div>
                <div class="col">
                  <%= f.input :theme_primary_text_color, label: "Primary",
                              input_html: { type: "color", class: "form-control-color" } %>
                </div>
                <div class="col">
                  <%= f.input :theme_secondary_text_color, label: "Secondary",
                              input_html: { type: "color", class: "form-control-color" } %>
                </div>
                <div class="col">
                  <%= f.input :theme_button_color, label: "Buttons",
                              input_html: { type: "color", class: "form-control-color" } %>
                </div>
              </div>

              <%= f.input :theme_heading_font, label: "Heading font", include_blank: false,
                          collection: Organization::FONT_CHOICES.map { |key, cfg| [cfg[:label], key] } %>
              <%= f.input :theme_body_font, label: "Body font", include_blank: false,
                          collection: Organization::FONT_CHOICES.map { |key, cfg| [cfg[:label], key] } %>
            </fieldset>

            <%= f.button :submit, "Save organization", class: "btn btn-primary" %>
          </fieldset>
        </section>
      <% end %>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12">
      <section class="settings-card settings-card--danger mb-4">
        <h2 class="h5 mb-1">Delete account</h2>
        <p class="text-muted small mb-3">This can't be undone.</p>

        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#delete-account-modal">
          Delete account
        </button>
        <%= render "shared/confirm_modal", id: "delete-account-modal", title: "Delete account",
              body: "This can't be undone.", url: registration_path(resource_name),
              confirm_label: "Delete account", type_to_confirm: "DELETE" %>
      </section>

      <% if current_user.workspace_owner? %>
        <section class="settings-card settings-card--danger">
          <h2 class="h5 mb-1">Delete workspace</h2>
          <p class="text-muted small mb-3">
            Permanently deletes all your loops and feedback, and removes every teammate. Your own account stays active.
          </p>

          <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#delete-workspace-modal">
            Delete workspace
          </button>
          <%= render "shared/confirm_modal", id: "delete-workspace-modal", title: "Delete workspace",
                body: "Permanently deletes all your loops and feedback, and removes every teammate. Your own account stays active.",
                url: workspace_path, confirm_label: "Delete workspace", type_to_confirm: "DELETE" %>
        </section>
      <% end %>
    </div>
  </div>
</div>
