<% content_for :title, "Analyse" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Analyse</h1>

    <% if @loops.any? %>
      <div style="min-width: 260px;">
        <select class="form-select" onchange="if (this.value) { window.location.href = this.value }">
          <% @loops.each do |loop_record| %>
            <option value="<%= analyse_path(loop_record.slug) %>" <%= "selected" if @loop && loop_record.id == @loop.id %>>
              <%= loop_record.name %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>
  </div>

  <% if @loop.nil? %>
    <div class="alert alert-secondary">
      You don't have any loops yet. Create one to start collecting feedback.
    </div>
  <% else %>
    <h2 class="mb-4">Overview of #<%= @loop.name %></h2>

    <div class="row g-4 mb-4">
      <div class="col-md-8">
        <div class="border rounded p-4 h-100 d-flex align-items-center justify-content-center text-muted" style="min-height: 220px;">
          Chart coming soon
        </div>
      </div>
      <div class="col-md-4">
        <div class="border rounded p-4 h-100 d-flex align-items-center justify-content-center text-muted" style="min-height: 220px;">
          Summary coming soon
        </div>
      </div>
    </div>

    <h3 class="mb-3">Feedback</h3>

    <% if @feedbacks.empty? %>
      <div class="alert alert-light border text-center py-5">
        No feedback yet
      </div>
    <% else %>
      <div class="d-flex flex-column gap-3">
        <% @feedbacks.each do |feedback| %>
          <div class="border rounded p-3">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="fw-semibold"><%= feedback.respondent_email.presence || "Anonymous respondent" %></span>
              <span class="text-muted small"><%= feedback.created_at.strftime("%b %d, %Y at %I:%M %p") %></span>
            </div>
            <p class="mb-0" style="white-space: pre-wrap;"><%= feedback.transcript %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
