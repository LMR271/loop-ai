<% widget_url = "#{request.base_url}/widget.js" %>

<details class="deploy-loop border rounded">
  <summary class="deploy-loop__summary">
    <span class="deploy-loop__summary-content">
      <span class="deploy-loop__name"><%= loop.name.presence || "Untitled loop" %></span>
    </span>
    <span class="deploy-loop__summary-meta">
      <span class="badge text-bg-success">Live</span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </span>
  </summary>

  <div class="deploy-loop__details">
    <article class="deploy-detail-card deploy-share-card card" data-controller="clipboard">
      <div>
        <p class="deploy-detail-card__eyebrow">Public link</p>
        <h3 class="h5 mb-1">Share this loop</h3>
        <p class="text-muted mb-0">Copy the link to send respondents to this interview.</p>
      </div>
      <div class="respondent-link-controls deploy-share-card__controls">
        <input id="active-respondent-link-<%= loop.id %>" type="text" class="form-control bg-white respondent-link-controls__url" readonly
               value="<%= respondent_url(loop.slug) %>" aria-label="Public link for <%= loop.name %>"
               data-clipboard-target="source">
        <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                data-clipboard-target="button">Copy</button>
        <%= link_to "Open", respondent_url(loop.slug), class: "btn btn-outline-secondary respondent-link-controls__button",
              target: "_blank", rel: "noopener" %>
      </div>
      <%= button_to "Pause Loop", deactivate_loop_path(loop), params: { return_to: "deploy" }, class: "btn btn-outline-secondary btn-sm" %>
    </article>

    <article class="deploy-detail-card card">
      <div>
        <p class="deploy-detail-card__eyebrow">Email invite</p>
        <h3 class="h5 mb-1">Invite respondents by email</h3>
        <p class="text-muted mb-0">One address per line, or separated by commas.</p>
      </div>
      <%= form_with url: deploy_invites_path(loop_id: loop.id), method: :post do |form| %>
        <textarea name="emails" class="form-control mb-2" rows="3"
                  placeholder="jamie@example.com&#10;alex@example.com" required></textarea>
        <%= form.submit "Send invites", class: "btn btn-primary btn-sm" %>
      <% end %>
    </article>

    <article class="deploy-detail-card card" data-controller="clipboard">
      <div>
        <p class="deploy-detail-card__eyebrow">Embed on your site</p>
        <h3 class="h5 mb-1">Inline embed</h3>
        <p class="text-muted mb-0">Paste this where you want the interview to appear on the page.</p>
      </div>
      <div class="respondent-link-controls">
        <textarea class="form-control bg-white respondent-link-controls__url" readonly rows="2"
                  data-clipboard-target="source"><script src="<%= widget_url %>" data-loop-slug="<%= loop.slug %>" data-mode="inline"></script></textarea>
        <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                data-clipboard-target="button">Copy</button>
      </div>
    </article>

    <article class="deploy-detail-card card" data-controller="clipboard">
      <div>
        <p class="deploy-detail-card__eyebrow">Floating widget</p>
        <h3 class="h5 mb-1">Add a feedback button</h3>
        <p class="text-muted mb-0">Adds a floating button (bottom-right) to any page.</p>
      </div>
      <div class="respondent-link-controls">
        <textarea class="form-control bg-white respondent-link-controls__url" readonly rows="2"
                  data-clipboard-target="source"><script src="<%= widget_url %>" data-loop-slug="<%= loop.slug %>"></script></textarea>
        <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                data-clipboard-target="button">Copy</button>
      </div>
    </article>

    <article class="deploy-detail-card card" data-controller="clipboard">
      <div>
        <p class="deploy-detail-card__eyebrow">Email newsletters</p>
        <h3 class="h5 mb-1">Feedback button</h3>
        <p class="text-muted mb-0">Paste this HTML into a newsletter template.</p>
      </div>
      <div class="respondent-link-controls">
        <textarea class="form-control bg-white respondent-link-controls__url" readonly rows="3"
                  data-clipboard-target="source"><a href="<%= respondent_url(loop.slug) %>" style="display:inline-block;padding:12px 24px;background:#0D6EFD;color:#fff;text-decoration:none;border-radius:6px;font-family:sans-serif;">Give Feedback</a></textarea>
        <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                data-clipboard-target="button">Copy</button>
      </div>
    </article>
  </div>
</details>
