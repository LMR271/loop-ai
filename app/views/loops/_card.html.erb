<article class="loop-card">
  <div class="loop-card__content">
    <div class="d-flex align-items-center gap-2 mb-2">
      <h2 class="h4 mb-0"><%= loop_record.name.presence || "Untitled loop" %></h2>
      <span class="badge text-bg-light"><%= loop_record.status.presence || "draft" %></span>
      <% if loop_record.pending_approval? %>
        <span class="badge text-bg-warning">Pending approval</span>
      <% end %>
    </div>
    <% if loop_record.description.present? %>
      <p class="text-muted mb-3"><%= loop_record.description %></p>
    <% end %>
    <p class="loop-card__meta mb-0">
      <%= pluralize(loop_record.feedbacks.size, "response") %> · Created <%= time_ago_in_words(loop_record.created_at) %> ago
    </p>
  </div>
  <div class="loop-card__actions">
    <%= link_to analyze_path(loop_record.slug), class: "btn btn-outline-secondary",
          "aria-label": "Analyze #{loop_record.name.presence || "this loop"}", title: "Analyze",
          data: { controller: "tooltip", bs_placement: "top" } do %>
      <i class="fa-solid fa-chart-simple" aria-hidden="true"></i>
    <% end %>
    <%= link_to edit_loop_path(loop_record), class: "btn btn-outline-secondary",
          "aria-label": "Edit #{loop_record.name.presence || "this loop"}", title: "Edit",
          data: { controller: "tooltip", bs_placement: "top" } do %>
      <i class="fa-solid fa-pen" aria-hidden="true"></i>
    <% end %>
    <% if current_user_workspace_admin? %>
      <% loop_display_name = loop_record.name.presence || "this loop" %>
      <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#delete-loop-<%= loop_record.id %>"
              aria-label="<%= "Delete #{loop_display_name}" %>" title="Delete"
              data-controller="tooltip" data-bs-placement="top">
        <i class="fa-solid fa-trash" aria-hidden="true"></i>
      </button>
      <%= render "shared/confirm_modal", id: "delete-loop-#{loop_record.id}", title: "Delete loop",
            body: "Delete #{loop_display_name}? This also removes its feedback and questions.",
            url: loop_path(loop_record) %>
    <% end %>
    <% if current_user_workspace_admin? && loop_record.pending_approval? %>
      <%= button_to approve_loop_path(loop_record), method: :post, class: "btn btn-outline-success",
            "aria-label": "Approve #{loop_record.name.presence || "this loop"}", title: "Approve",
            data: { controller: "tooltip", bs_placement: "top" } do %>
        <i class="fa-solid fa-check" aria-hidden="true"></i>
      <% end %>
    <% end %>
  </div>
</article>
