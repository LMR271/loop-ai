<p>Hi <%= @loop.user.name %>,</p>

<p>New feedback just came in on <strong><%= @loop.name %></strong>.</p>

<% if @feedback.sentiment.present? %>
  <p>Sentiment: <strong><%= @feedback.sentiment.capitalize %></strong></p>
<% end %>

<%= render "mailer/button", text: "View it in Analyse", url: @analyse_url %>
