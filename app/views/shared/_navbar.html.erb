<nav class="app-navbar navbar" aria-label="Workspace actions" data-controller="theme">
  <% unless user_signed_in? %>
    <%= link_to root_path, class: "app-navbar__brand", aria: { label: "Loop AI home" } do %>
      <%= image_tag "lightbulb.svg",
            alt: "LoopAI",
            class: "app-navbar__logo" %>
    <% end %>
  <% end %>

  <% if user_signed_in? %>
    <div class="app-navbar__actions">
      <%= form_with url: loops_path, method: :get, class: "app-search", role: "search" do |form| %>
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        <%= form.search_field :q,
              value: params[:q],
              class: "form-control",
              placeholder: "Search loops",
              aria: { label: "Search loops" } %>
      <% end %>

      <div class="dropdown">
        <button type="button" class="btn app-alert-button position-relative" data-bs-toggle="dropdown"
                aria-label="Notifications" aria-expanded="false">
          <i class="fa-regular fa-bell" aria-hidden="true"></i>
          <% if new_feedback_total.positive? %>
            <span class="app-alert-badge badge rounded-pill text-bg-danger"><%= new_feedback_total %></span>
          <% end %>
        </button>
        <ul class="dropdown-menu dropdown-menu-end app-notifications-menu">
          <% if loops_with_new_feedback.any? %>
            <% loops_with_new_feedback.each do |loop_record| %>
              <li>
                <%= link_to analyze_path(loop_record.slug), class: "dropdown-item" do %>
                  <strong><%= loop_record.name %></strong> —
                  <%= pluralize(new_feedback_count_for(loop_record), "new response") %>
                <% end %>
              </li>
            <% end %>
          <% else %>
            <li class="app-notifications-empty"><span class="dropdown-item-text text-muted">No new responses</span></li>
          <% end %>
        </ul>
      </div>

      <% unless current_page?(new_loop_path) %>
        <%= link_to new_loop_path, class: "app-new-loop-button" do %>
          <i class="fa-solid fa-plus" aria-hidden="true"></i>
          <span>New Loop</span>
        <% end %>
      <% end %>

      <div class="dropdown">
        <button class="btn app-user-menu" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open account menu">
          <% if current_organization&.logo&.attached? %>
            <%= image_tag current_organization.logo.variant(resize_to_limit: [64, 64]), class: "app-user-menu__avatar", alt: "" %>
          <% else %>
            <i class="fa-regular fa-circle-user" aria-hidden="true"></i>
          <% end %>
          <span class="app-user-menu__name"><%= current_user.name.presence || current_user.email %></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end app-user-menu__dropdown" aria-labelledby="userMenu">
          <li>
            <%= link_to question_library_entries_path, class: "dropdown-item" do %>
              <i class="fa-solid fa-book-open" aria-hidden="true"></i>
              <span>Question Library</span>
            <% end %>
          </li>
          <li>
            <%= link_to team_path, class: "dropdown-item" do %>
              <i class="fa-solid fa-users" aria-hidden="true"></i>
              <span>Team</span>
            <% end %>
          </li>
          <li>
            <%= link_to edit_user_registration_path, class: "dropdown-item" do %>
              <i class="fa-solid fa-gear" aria-hidden="true"></i>
              <span>Settings</span>
            <% end %>
          </li>
          <li><hr class="dropdown-divider"></li>
          <li>
            <button type="button" class="dropdown-item" data-action="click->theme#toggle">
              <i class="fa-solid fa-moon" data-theme-target="icon" aria-hidden="true"></i>
              <span data-theme-target="label">Dark mode</span>
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
          <li>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" do %>
              <i class="fa-solid fa-arrow-right-from-bracket" aria-hidden="true"></i>
              <span>Log out</span>
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="app-navbar__actions public-navbar__actions">
      <%= link_to "Log in", new_user_session_path, class: "btn app-login-button" %>
    </div>
  <% end %>
</nav>
