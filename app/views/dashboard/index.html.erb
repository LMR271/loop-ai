<% content_for :title, "Dashboard" %>

<div class="page-content--wide container py-4">
  <% if flash[:show_org_setup] %>
    <%= render "org_setup_banner" %>
  <% end %>

  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
    <%= render "shared/page_header", title: "Dashboard",
          subtitle: "An overview of your feedback loops." %>

    <button type="button" class="btn btn-outline-secondary flex-shrink-0" data-bs-toggle="modal" data-bs-target="#stat-settings-modal"
            aria-label="Customize dashboard stats" title="Customize stats" data-controller="tooltip" data-bs-placement="top">
      <i class="fa-solid fa-gear" aria-hidden="true"></i>
    </button>
  </div>

  <div class="row g-3 mb-5">
    <% @stats.each do |stat| %>
      <div class="col-6 col-md-3">
        <%= render "stat_card", stat: stat %>
      </div>
    <% end %>
  </div>

  <section class="loops-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-1">
      <h2 class="h4 mb-0">Recent Loops</h2>
      <% if @recent_loops.any? %>
        <%= link_to "View all loops", loops_path, class: "btn btn-sm btn-outline-secondary" %>
      <% end %>
    </div>

    <% if @recent_loops.any? %>
      <div class="loops-list">
        <% @recent_loops.each do |loop_record| %>
          <%= render "loops/card", loop_record: loop_record %>
        <% end %>
      </div>
    <% else %>
      <div class="loops-empty-state text-center">
        <p class="text-muted mb-0">No loops yet. Create your first loop to start collecting feedback.</p>
      </div>
    <% end %>
  </section>
</div>

<div class="modal fade" id="stat-settings-modal" tabindex="-1" aria-labelledby="stat-settings-modal-label" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <%= form_with url: dashboard_stat_preferences_path, method: :patch, data: { controller: "stat-settings" } do %>
        <div class="modal-header">
          <h2 class="modal-title h5" id="stat-settings-modal-label">Customize stats</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <p class="text-muted small">Choose exactly 4 stats to show, and drag to reorder them.</p>

          <ul class="list-group">
            <% @stat_keys_for_settings.each do |key| %>
              <li class="list-group-item d-flex align-items-center gap-2"
                  draggable="true"
                  data-stat-settings-target="item"
                  data-action="dragstart->stat-settings#dragStart dragover->stat-settings#dragOver dragend->stat-settings#dragEnd">
                <span class="text-muted" aria-hidden="true"><i class="fa-solid fa-grip-vertical"></i></span>
                <div class="form-check flex-grow-1 mb-0">
                  <input type="checkbox" class="form-check-input" name="stat_keys[]" value="<%= key %>" id="stat-key-<%= key %>"
                         data-stat-settings-target="checkbox" data-action="change->stat-settings#limitSelection"
                         <%= "checked" if @selected_stat_keys.include?(key) %>>
                  <label class="form-check-label" for="stat-key-<%= key %>"><%= DashboardStats::LABELS[key] %></label>
                </div>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" data-stat-settings-target="submit">Save</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
