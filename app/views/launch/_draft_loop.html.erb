<details class="deploy-loop border rounded">
  <summary class="deploy-loop__summary">
    <span class="deploy-loop__summary-content">
      <span class="deploy-loop__name">#<%= loop.name.presence || "Untitled loop" %></span>
      <% if loop.description.present? %>
        <span class="deploy-loop__description"><%= loop.description %></span>
      <% end %>
    </span>
    <span class="deploy-loop__summary-meta">
      <span class="badge text-bg-light"><%= loop.status %></span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </span>
  </summary>

  <div class="deploy-loop__details">
    <article class="deploy-detail-card deploy-status-card card">
      <div class="deploy-status-card__content">
        <p class="deploy-detail-card__eyebrow">Loop status</p>

        <% if loop.locked? %>
          <h3 class="h5 mb-1">This loop is currently paused</h3>
          <p class="text-muted mb-0">
            This loop has been launched before and is currently paused. It can be relaunched, but it can no longer be edited.
          </p>
        <% else %>
          <h3 class="h5 mb-1">This loop is not live</h3>
          <p class="text-muted mb-0">
            Launch it to make it available to respondents.
          </p>
        <% end %>
      </div>
      <div class="deploy-status-card__actions">
        <% if current_user_workspace_admin? %>
          <%= button_to activate_loop_path(loop), params: { return_to: "launch" }, class: "btn btn-primary",
                "aria-label": "Launch #{loop.name.presence || "this loop"}", title: "Launch",
                data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-play" aria-hidden="true"></i>
          <% end %>
        <% end %>

        <% unless loop.locked? %>
          <%= link_to edit_loop_path(loop), class: "btn btn-outline-secondary",
                "aria-label": "Edit #{loop.name.presence || "this loop"}", title: "Edit",
                data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <% end %>
        <% end %>
      </div>
    </article>
  </div>
</details>
