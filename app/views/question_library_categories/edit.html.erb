<% content_for :title, "Rename category · Loop AI" %>

<main class="container py-5" style="max-width: 760px;">
  <h1 class="mb-1">Rename category</h1>
  <p class="text-muted mb-4">Questions in this category will keep their new category name.</p>

  <%= form_with model: @category do |form| %>
    <% if @category.errors.any? %>
      <div class="alert alert-danger"><%= @category.errors.full_messages.to_sentence %></div>
    <% end %>
    <div class="mb-4">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", required: true, autofocus: true %>
    </div>
    <div class="d-flex gap-2">
      <%= form.submit "Save changes", class: "btn app-new-loop-button" %>
      <%= link_to "Cancel", question_library_entries_path, class: "btn app-login-button" %>
    </div>
  <% end %>
</main>
