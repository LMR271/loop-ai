<% content_for :title, "Dashboard" %>

<div class="container py-4">
  <div class="d-flex justify-content-end mb-4">
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#stat-settings-modal" aria-label="Customize dashboard stats">
      ⚙
    </button>
  </div>

  <div class="row g-3 mb-5">
    <% @stats.each do |stat| %>
      <div class="col-6 col-md-3">
        <div class="border rounded p-3 h-100 text-center">
          <p class="text-uppercase text-muted small mb-1"><%= stat[:label] %></p>
          <p class="fs-2 fw-bold mb-1"><%= stat[:value] %></p>
          <p class="text-muted small mb-0"><%= stat[:subtext] %></p>
        </div>
      </div>
    <% end %>
  </div>

  <h2 class="h4 mb-1">Feedback Loops</h2>
  <p class="text-muted mb-3">Recent Projects</p>

  <% if @recent_loops.any? %>
    <div class="loops-list">
      <% @recent_loops.each do |loop_record| %>
        <article class="loop-card" style="justify-content: flex-start; gap: 2rem;">
          <% if loop_record.logo_url.present? %>
            <%= image_tag loop_record.logo_url, class: "rounded-circle", style: "width: 100px; height: 100px; object-fit: cover; flex-shrink: 0;" %>
          <% else %>
            <div class="rounded-circle" style="width: 100px; height: 100px; flex-shrink: 0; <%= loop_avatar_gradient(loop_record) %>"></div>
          <% end %>

          <div class="loop-card__content text-start">
            <h3 class="h5 mb-2">#<%= loop_record.name %></h3>
            <p class="text-muted mb-3"><%= truncate(loop_record.description, length: 200) %></p>
            <%= link_to "Analyse", analyse_path(loop_record.slug), class: "btn btn-sm btn-outline-secondary" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="loops-empty-state text-center">
      <p class="text-muted mb-0">No loops yet. Create your first loop to start collecting feedback.</p>
    </div>
  <% end %>
</div>

<div class="modal fade" id="stat-settings-modal" tabindex="-1" aria-labelledby="stat-settings-modal-label" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <%= form_with url: dashboard_stat_preferences_path, method: :patch do %>
        <div class="modal-header">
          <h2 class="modal-title h5" id="stat-settings-modal-label">Customize stats</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <p class="text-muted small">Choose up to 4 stats to show, and drag to reorder them.</p>

          <ul class="list-group" data-controller="stat-settings">
            <% @stat_keys_for_settings.each do |key| %>
              <li class="list-group-item d-flex align-items-center gap-2"
                  draggable="true"
                  data-stat-settings-target="item"
                  data-action="dragstart->stat-settings#dragStart dragover->stat-settings#dragOver dragend->stat-settings#dragEnd">
                <span class="text-muted" aria-hidden="true">⠿</span>
                <div class="form-check flex-grow-1 mb-0">
                  <input type="checkbox" class="form-check-input" name="stat_keys[]" value="<%= key %>" id="stat-key-<%= key %>"
                         data-stat-settings-target="checkbox" data-action="change->stat-settings#limitSelection"
                         <%= "checked" if @selected_stat_keys.include?(key) %>>
                  <label class="form-check-label" for="stat-key-<%= key %>"><%= DashboardStats::LABELS[key] %></label>
                </div>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
