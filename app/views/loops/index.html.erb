<% content_for :title, "Your loops · Loop AI" %>

<section class="loops-dashboard">
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-5">
    <div>
      <p class="text-uppercase text-muted fw-semibold small mb-1">Feedback loops</p>
      <h1 class="mb-1"><%= @query.present? ? "Search results" : "Your loops" %></h1>
      <p class="text-muted mb-0"><%= @query.present? ? "Results for “#{@query}”" : "Review feedback activity and remove loops you no longer need." %></p>
    </div>
    <%= link_to "New Loop", new_loop_path, class: "btn btn-primary btn-lg" %>
  </div>

  <% if @loops.any? %>
    <section class="loops-list" aria-label="Your loops">
      <% @loops.each do |loop| %>
        <article class="loop-card">
          <div class="loop-card__content">
            <div class="d-flex align-items-center gap-2 mb-2">
              <h2 class="h4 mb-0"><%= loop.name.presence || "Untitled loop" %></h2>
              <span class="badge text-bg-light"><%= loop.status.presence || "draft" %></span>
              <% if loop.pending_approval? %>
                <span class="badge text-bg-warning">Pending approval</span>
              <% end %>
            </div>
            <% if loop.description.present? %>
              <p class="text-muted mb-3"><%= loop.description %></p>
            <% end %>
            <p class="loop-card__meta mb-0">
              <%= pluralize(loop.feedbacks.size, "response") %> · Created <%= time_ago_in_words(loop.created_at) %> ago
            </p>
          </div>
          <div class="loop-card__actions">
            <% if current_user_workspace_admin? && loop.pending_approval? %>
              <%= button_to "Approve", approve_loop_path(loop), method: :post, class: "btn btn-outline-success" %>
            <% end %>
            <% if current_user_workspace_admin? %>
              <%= button_to "Delete", loop_path(loop), method: :delete,
                    class: "btn btn-outline-danger",
                    form: { data: { turbo_confirm: "Delete #{loop.name.presence || "this loop"}? This also removes its feedback and questions." } } %>
            <% end %>
          </div>
        </article>
      <% end %>
    </section>
  <% else %>
    <section class="loops-empty-state text-center" aria-labelledby="empty-loops-heading">
      <div class="loops-empty-state__icon" aria-hidden="true">↻</div>
      <h2 id="empty-loops-heading"><%= @query.present? ? "No matching loops" : "No loops yet" %></h2>
      <p class="text-muted mb-4"><%= @query.present? ? "Try a different search term." : "Create your first loop to start collecting and understanding customer feedback." %></p>
      <%= link_to(@query.present? ? "Clear search" : "New Loop", @query.present? ? loops_path : new_loop_path, class: "btn btn-primary") %>
    </section>
  <% end %>
</section>
