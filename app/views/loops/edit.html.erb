<% content_for :title, "Edit #{@loop.name} | Loop AI" %>

<main class="page-content--wide container py-5">
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h1 class="mb-1">Edit <%= @loop.name %></h1>
      <p class="text-muted mb-0">Keep the conversation focused and in the order that makes sense.</p>
    </div>
    <div class="ms-3 text-end text-nowrap">
      <% if @loop.pending_approval? %>
        <span class="badge bg-warning fs-6 d-block mb-2">Pending approval</span>
        <% if current_user_workspace_admin? %>
          <%= button_to approve_loop_path(@loop), class: "btn btn-outline-success btn-sm",
                "aria-label": "Approve", title: "Approve", data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-check" aria-hidden="true"></i>
          <% end %>
        <% end %>
      <% elsif @loop.active? %>
        <span class="badge bg-success fs-6 d-block mb-2">Active</span>
        <% if current_user_workspace_admin? %>
          <%= button_to deactivate_loop_path(@loop), class: "btn btn-outline-secondary btn-sm",
                "aria-label": "Deactivate", title: "Deactivate", data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-pause" aria-hidden="true"></i>
          <% end %>
        <% end %>
      <% elsif current_user_workspace_admin? %>
        <%= button_to activate_loop_path(@loop), class: "btn btn-primary",
              "aria-label": "Activate", title: "Activate", data: { controller: "tooltip", bs_placement: "top" } do %>
          <i class="fa-solid fa-play" aria-hidden="true"></i>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @loop.active? %>
    <div class="card border-0 bg-light mb-4" data-controller="clipboard">
      <div class="card-body">
        <label for="respondent-link" class="form-label fw-semibold mb-1">Respondent link</label>
        <p class="text-muted small mb-2">Share this link so people can talk to your agent.</p>
        <div class="respondent-link-controls">
          <input id="respondent-link" type="text" class="form-control bg-white respondent-link-controls__url" readonly
                 value="<%= respondent_url(@loop.slug) %>"
                 data-clipboard-target="source">
          <button class="btn btn-outline-secondary respondent-link-controls__button" type="button" data-action="clipboard#copy"
                  data-clipboard-target="button" aria-label="Copy link" title="Copy"
                  data-controller="tooltip" data-bs-placement="top">
            <i class="fa-solid fa-copy" aria-hidden="true"></i>
          </button>
          <%= link_to respondent_url(@loop.slug),
                class: "btn btn-outline-secondary respondent-link-controls__button", target: "_blank", rel: "noopener",
                "aria-label": "Open link", title: "Open", data: { controller: "tooltip", bs_placement: "top" } do %>
            <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%= render "form", loop: @loop %>
</main>
