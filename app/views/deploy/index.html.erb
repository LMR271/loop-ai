<% content_for :title, "Deploy loops · Loop AI" %>

<section class="deploy-dashboard mx-auto">
  <div class="deploy-header mb-5">
    <div>
      <p class="text-uppercase text-muted fw-semibold small mb-1">Deployment</p>
      <h1 class="mb-1">Deploy your loops</h1>
      <p class="text-muted mb-0">Select a loop to launch it and share its public interview link.</p>
    </div>

    <div class="deploy-active-overview">
      <%= render "dashboard/stat_card", stat: @active_loops_overview %>
    </div>
  </div>

  <div class="row g-4 align-items-start">
    <section class="col-lg-8" aria-labelledby="draft-loops-heading">
      <div class="deploy-section-heading">
        <h2 id="draft-loops-heading" class="h3 mb-0">Draft Loops</h2>
      </div>

      <% if @draft_loops.any? %>
        <div class="deploy-list" aria-label="Draft loops">
          <%= render partial: "draft_loop", collection: @draft_loops, as: :loop %>
        </div>
      <% else %>
        <p class="deploy-empty-message">There are no draft loops.</p>
      <% end %>
    </section>

    <section class="col-lg-4" aria-labelledby="active-loops-heading">
      <div class="deploy-section-heading">
        <h2 id="active-loops-heading" class="h3 mb-0">Active Loops</h2>
      </div>

      <% if @active_loops.any? %>
        <div class="deploy-active-list" aria-label="Active loops">
          <%= render partial: "active_loop", collection: @active_loops, as: :loop %>
        </div>
      <% else %>
        <p class="deploy-empty-message deploy-empty-message--centered">There are no currently active loops.</p>
      <% end %>
    </section>
  </div>
</section>
