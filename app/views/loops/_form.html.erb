<div data-controller="questions-form">
<%= form_with model: loop do |form| %>
  <% if loop.errors.any? %>
    <div class="alert alert-danger">
      <%= loop.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", autofocus: true, required: true %>
    </div>

    <div class="col-md-6">
      <% if @loop.image.attached? %>
        <div class="mb-3">
          <%= image_tag loop.image.variant(resize_to_limit: [300, 300]),
              class: "img-fluid rounded border mb-3" %>
        </div>

        <div class="form-check mb-3">
          <%= form.check_box :remove_image, class: "form-check-input" %>
          <%= form.label :remove_image, "Remove current image", class: "form-check-label" %>
        </div>
      <% end %>

      <%= form.label :image, "Image (optional)", class: "form-label" %>
      <%= form.file_field :image,
          class: "form-control",
          accept: "image/png,image/jpeg,image/webp" %>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <p class="text-muted small mb-3">
            <i class="fa-solid fa-robot" aria-hidden="true"></i>
            This field is not shown to respondents — it's context for the AI, so it better understands what outcome you want from their answers.
          </p>

          <div class="mb-0">
            <%= form.label :description, "What do you want feedback on?", class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 4,
                  placeholder: "Describe the product, decision, or experience you want to understand." %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <p class="text-muted small mb-3">
            <i class="fa-solid fa-eye" aria-hidden="true"></i>
            The two fields below are shown to respondents on the page where they give feedback — write them with that audience in mind.
          </p>

          <div class="mb-3">
            <%= form.label :respondent_title, "Title", class: "form-label" %>
            <%= form.text_field :respondent_title, class: "form-control",
                  placeholder: "e.g. Help us improve our checkout flow" %>
          </div>

          <div class="mb-0">
            <%= form.label :respondent_description, "Description", class: "form-label" %>
            <%= form.text_area :respondent_description, class: "form-control", rows: 3,
                  placeholder: "A sentence or two telling respondents what this is about and what to expect." %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section aria-labelledby="questions-heading">
    <div class="mb-3 d-flex justify-content-between align-items-end gap-3">
      <div>
        <h2 id="questions-heading" class="h4 mb-1">Conversation questions</h2>
        <p class="text-muted mb-0">These guide the feedback conversation. Use the arrows to set their order.</p>
      </div>
      <button type="button" class="btn btn-outline-secondary flex-shrink-0" data-bs-toggle="modal" data-bs-target="#insertQuestionFromLibraryModal">
        <i class="fa-solid fa-book-open" aria-hidden="true"></i>
        Insert from Library
      </button>
    </div>

    <div data-questions-form-target="list">
      <%= form.fields_for :questions do |question_fields| %>
        <%= render "question_fields", question_fields: question_fields %>
      <% end %>
    </div>

    <button type="button" class="btn btn-outline-secondary question-add-control w-100" data-action="questions-form#add">
      <i class="fa-solid fa-plus" aria-hidden="true"></i>
      Add another question
    </button>

    <template data-questions-form-target="template">
      <%= form.fields_for :questions, Question.new, child_index: "NEW_RECORD" do |question_fields| %>
        <%= render "question_fields", question_fields: question_fields %>
      <% end %>
    </template>
  </section>

  <div class="mt-4 d-flex gap-2">
    <%= button_tag type: "submit", class: "btn btn-primary loop-form__submit" do %>
      <span><%= loop.persisted? ? "Save changes" : "Create loop" %></span>
      <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
    <% end %>
    <% if loop.persisted? %>
      <%= link_to "Cancel", edit_loop_path(loop), class: "btn btn-outline-secondary" %>
    <% end %>
  </div>
<% end %>

<%= render "question_library_modal", library_entries: @question_library_entries, library_categories: @question_library_categories %>
</div>
