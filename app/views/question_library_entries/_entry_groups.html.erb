<% grouped_entries = entries.group_by { |entry| entry.category.presence } %>
<% categories.to_a.each { |category| grouped_entries[category.name] ||= [] } if local_assigns[:manage] %>
<% grouped_entries.sort_by { |category, _| [category.present? ? 1 : 0, category.to_s.downcase] }.each do |category, category_entries| %>
  <% category_record = local_assigns[:categories]&.find { |item| item.name == category } %>
  <section class="card mb-3 library-category" data-library-search-target="group" data-library-search-category="<%= (category.presence || "No Category").downcase %>">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <h2 class="h5 mb-0"><%= category.presence || "No Category" %></h2>
        <% if local_assigns[:manage] && category_record %>
          <div class="d-flex gap-2 flex-shrink-0">
            <%= link_to "Rename", edit_question_library_category_path(category_record), class: "btn btn-sm btn-outline-secondary" %>
            <% if category_entries.any? %>
              <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCategoryModal<%= category_record.id %>">Delete</button>
            <% else %>
              <%= button_to "Delete", question_library_category_path(category_record), method: :delete,
                    class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Delete the category #{category_record.name}?" } } %>
            <% end %>
          </div>
        <% end %>
      </div>
      <% if category_entries.any? %>
      <div class="list-group list-group-flush">
        <% category_entries.sort_by { |entry| entry.content.downcase }.each do |entry| %>
          <div class="list-group-item px-0 d-flex align-items-start justify-content-between gap-3 library-entry" data-library-search-target="entry" data-library-search-content="<%= entry.content.downcase %>">
            <p class="mb-0"><%= entry.content %></p>
            <% if local_assigns[:manage] %>
              <div class="d-flex gap-2 flex-shrink-0">
                <%= link_to "Edit", edit_question_library_entry_path(entry), class: "btn btn-sm btn-outline-secondary" %>
                <%= button_to "Delete", question_library_entry_path(entry), method: :delete,
                      class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Delete this library question?" } } %>
              </div>
            <% else %>
              <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0"
                      data-action="questions-form#insertFromLibrary"
                      data-questions-form-content-param="<%= entry.content %>"
                      data-questions-form-use-url-param="<%= use_question_library_entry_path(entry) %>">
                Insert
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
      <% elsif local_assigns[:manage] %>
        <p class="text-muted mb-0">No questions in this category yet.</p>
      <% end %>
    </div>
  </section>
  <% if local_assigns[:manage] && category_record && category_entries.any? %>
    <%= render "delete_category_modal", category: category_record, entries_count: category_entries.count,
          other_categories: categories.reject { |item| item == category_record } %>
  <% end %>
<% end %>
