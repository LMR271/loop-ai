<% content_for :title, "Share your feedback - #{@loop.name}" %>

<div class="respondent-card" data-controller="interview" data-interview-slug-value="<%= @loop.slug %>">
  <header class="respondent-card__brand text-center">
    <% if @loop.logo_url.present? %>
      <img src="<%= @loop.logo_url %>" alt="Logo" class="respondent-logo">
    <% end %>
    <h1 class="respondent-card__title"><%= @loop.respondent_title.presence || "Share your feedback" %></h1>
    <p class="respondent-card__lead">
      <%= @loop.respondent_description.presence || "You've been invited to a short voice conversation. Tap play when you're ready — it only takes a few minutes." %>
    </p>
  </header>

  <div class="respondent-consent form-check text-start">
    <input type="checkbox"
           class="form-check-input"
           id="respondent-consent"
           data-interview-target="consentCheckbox"
           data-action="change->interview#toggleConsent">
    <label class="form-check-label small text-muted" for="respondent-consent">
      I consent to this conversation being recorded and analyzed by
      <%= @loop.organization.name.presence || "this organization" %>, as described in the
      <%= link_to "Terms", terms_path, target: "_blank", rel: "noopener" %> and
      <%= link_to "Privacy Policy", privacy_path, target: "_blank", rel: "noopener" %>.
    </label>
  </div>

  <div class="orb is-idle" data-interview-target="orb">
    <button type="button"
            class="orb__play"
            data-action="click->interview#start"
            data-interview-target="startButton"
            aria-label="Start interview"
            disabled>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg>
    </button>
  </div>

  <p data-interview-target="status" class="respondent-status" role="status" aria-live="polite"></p>

  <button type="button"
          class="btn btn-outline-secondary btn-sm respondent-end"
          data-action="click->interview#end"
          data-interview-target="endButton"
          hidden>
    End interview
  </button>

  <div class="respondent-thankyou text-center" data-interview-target="thankYou" hidden>
    <h2>Thanks for your feedback!</h2>
    <p class="text-muted">Your response has been recorded — you can close this tab now.</p>
  </div>

  <p class="respondent-meta text-muted">
    <small><%= pluralize(@loop.questions.count, "question") %></small>
  </p>
</div>

<p class="respondent-disclaimer text-muted small text-center">
  You'll be speaking with an AI voice agent, not a human.
</p>
