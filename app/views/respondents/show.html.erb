<div class="container mt-5">
  <div class="text-center mb-4">
    <% if @loop.logo_url.present? %>
      <img src="<%= @loop.logo_url %>" alt="<%= @loop.name %>" class="respondent-logo">
    <% end %>
    <h1><%= @loop.name %></h1>
    <p class="lead"><%= @loop.description %></p>
  </div>

    <div data-controller="interview" data-interview-slug-value="<%= @loop.slug %>">
      <button data-action="click->interview#start" data-interview-target="startButton" class="btn btn-primary btn-lg">
        🎙️ Start Interview
      </button>
      <button data-action="click->interview#end" data-interview-target="endButton" class="btn btn-outline-danger btn-lg" hidden>
        ⏹ End Interview
      </button>
      <p data-interview-target="status" class="mt-3 fw-semibold" role="status" aria-live="polite"></p>
      <p class="text-muted mt-1">
        <small><%= @loop.questions.count %> questions</small>
      </p>
    </div>
</div>
